{
  "bundle": {
    "require_mode": "luau",
    "excludes": [
      "@lune/**"
    ]
  },
  "generator": {
    "name": "readable",
    "column_span": 80
  },
  "rules": [
    "compute_expression",
    "convert_index_to_field",
    "filter_after_early_return",
    "remove_comments",
    "remove_debug_profiling",
    "remove_empty_do",
    "remove_function_call_parens",
    "remove_nil_declaration",
    "remove_spaces",
    "remove_types",
    "remove_unused_if_branch",
    "remove_unused_variable",
    "remove_unused_while"
  ]
}
